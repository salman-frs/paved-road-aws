{
  "name": "paved-road-aws",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "lint": "biome check .",
    "test": "vitest run",
    "typecheck": "pnpm --recursive --if-present typecheck",
    "build": "pnpm --recursive --if-present build",
    "scorecard": "tsx platform/scorecard/src/cli.ts",
    "template:test": "vitest run platform/templates/service-api/tests",
    "validate": "pnpm lint && pnpm test && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/node": "^25.5.0",
    "nunjucks": "^3.2.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0",
    "yaml": "^2.8.1"
  }
}
