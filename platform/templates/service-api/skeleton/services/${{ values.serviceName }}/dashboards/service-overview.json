{
  "title": "${{ values.serviceName }} Overview",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "title": "Request Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count{service_name=\"${{ values.serviceName }}\"}[5m]))"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum(rate(http_server_duration_count{service_name=\"${{ values.serviceName }}\",http_response_status_code=~\"5..\"}[5m]))"
        }
      ]
    }
  ]
}
